---
import ProjectCard from './ProjectCard.astro';
---
<section id="projects">
  <hr class="section-rule" />
  <p class="label">02 — projects</p>
  <h2>Things I built</h2>

  <div class="project-list">
    <ProjectCard 
      name="CacheVista" 
      year="2026" 
      tags="PyTorch, CLIP, FAISS, Python" 
      desc="A three layer hybrid cache designed to prevent VLMs from re-encoding previously seen images. The system combines exact hash matching with FAISS similarity detection and a trained MLP drift predictor to maintain zero accuracy loss while significantly reducing compute."
      slug="cachevista"
      github="https://github.com/lakshayxi/CacheVista"
    />
    <ProjectCard 
      name="SMLM" 
      year="2026" 
      tags="PyTorch, ViT, Transformer, Python" 
      desc="A vision language model built from scratch to understand the mechanics of multimodal alignment. I developed two variants at 28M and 6M parameters, uncovering critical insights about causal masking and the importance of parameter to token ratios in small scale training."
      slug="smlm"
      github="https://github.com/lakshayxi/SMLM"
    />
    <ProjectCard 
      name="Glimpse" 
      year="2026" 
      tags="PyTorch, CLIP, LoRA, Python" 
      desc="An empirical study of eight vision language fusion strategies on VQA v2 with frozen CLIP features. I implemented LoRA from scratch targeting 0.19% of parameters, and found that the simplest approach won: decomposing CLIP's existing alignment into three geometric signals outperformed every cross-attention variant I tested."
      slug="glimpse"
      github="https://github.com/lakshayxi/glimpse"
    />
    <ProjectCard 
      name="Maya" 
      year="2026" 
      tags="PyTorch, NLP, Python" 
      desc="Next word prediction for Hindi using a custom tokenizer. By testing architectures from Vanilla RNNs to BiLSTMs, I demonstrated that simpler models can often outperform complex ones in short context scenarios for morphologically rich languages."
      slug="maya"
      github="https://github.com/lakshayxi/maya"
    />
    <ProjectCard 
      name="PaperScope" 
      year="2026" 
      tags="Python, OpenReview API, Claude Code" 
      desc="A tool that quantifies optimism bias in peer reviews across 35 ML venues. It pulls live data from OpenReview to build per venue calibration profiles, allowing researchers to interpret reviews relative to historical distributions rather than raw scores."
      slug="paperscope"
      github="https://github.com/lakshayxi/PaperScope"
    />
    <div class="bottom-border"></div>
  </div>
</section>

<style>
  h2 {
    font-size: var(--size-xl);
    font-weight: 600;
    margin: 12px 0 48px 0;
  }
  .bottom-border {
    border-top: 1px solid var(--border);
  }
</style>