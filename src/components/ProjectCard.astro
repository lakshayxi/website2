---
const { name, year, tags, desc, slug, github } = Astro.props;
---
<div class="project-row">
  <div class="header">
    <span class="project-name">{name}</span>
    <span class="project-year">{year}</span>
  </div>
  <p class="project-tags">{tags}</p>
  <p class="project-desc">{desc}</p>
  <div class="links-row">
    <a href={`projects/${slug}/`} class="project-link">→ read more</a>
    {github && <a href={github} target="_blank" rel="noopener noreferrer" class="project-link github-link">github ↗</a>}
  </div>
</div>

<style>
  .project-row {
    padding: 28px 0;
    border-top: 1px solid var(--border);
  }
  .header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .project-name {
    font-size: var(--size-lg);
    font-weight: 600;
  }
  .project-year {
    font-size: var(--size-sm);
    color: var(--dim);
  }
  .project-tags {
    font-size: var(--size-xs);
    color: var(--dim);
    margin-top: 6px;
    letter-spacing: 0.04em;
  }
  .project-desc {
    font-size: var(--size-sm);
    color: var(--dim);
    margin-top: 8px;
    max-width: 520px;
  }
  .links-row {
    display: flex;
    gap: 24px;
    margin-top: 12px;
  }
  .project-link {
    font-size: var(--size-sm);
    text-decoration: none;
    color: var(--white);
  }
  .project-link:hover { color: var(--dim); }
</style>